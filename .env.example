# Base URL del backend real (autenticación). Ver README para más contexto.
VITE_API_BASE_URL=https://api.idempotencia.andrescortes.dev

# Solo para desarrollo local si el equipo de backend corre el API en HTTP:
# el propio backend aclara que esto solo sirve para /auth/register y /auth/login
# (OAuth requiere HTTPS).
# VITE_API_BASE_URL=http://localhost:5175

# Puerto host expuesto por docker-compose.yml (mapea a 80 dentro del contenedor).
# Solo tiene efecto con: docker compose --env-file .env.local up --build
FRONTEND_PORT=8080
